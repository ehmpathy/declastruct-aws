# SSO user credentials
#
# to find these values:
#   1. go to your SSO start URL: https://d-XXXXXXXXXX.awsapps.com/start/#/
#   2. sign in as admin — your username is what you sign in with, user emails will either match account emails or be visible from AWS Identity Center emails

# admin username — the username you sign in with at the SSO start URL
# e.g., SSO_ADMIN_USERNAME=admin
export SSO_ADMIN_USERNAME=__your_admin_username__

# admin email 
# e.g., SSO_ADMIN_EMAIL=admin@yourcompany.com
export SSO_ADMIN_EMAIL=__your_admin_email__

# demo email 
# e.g., SSO_DEMO_EMAIL=demo@yourcompany.com
export SSO_DEMO_EMAIL=__your_demo_email__
